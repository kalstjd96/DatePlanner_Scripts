# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# Unity & Unreal 공통 불필요한 파일 제외
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Ii]ntermediate/
[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/[Mm]emoryCaptures/

/[Rr]ecordings/

# Asset Store Tools (사용하지 않는 경우)
/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio, Gradle, 기타 설정 파일 제외
.vs/
.gradle/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity/Unreal Engine이 자동 생성하는 파일 제외
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt

# 빌드 관련 파일 제외
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics, Addressables 관련 자동 생성 파일 제외
crashlytics-build.properties
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/Aa]ssets/[Ss]treamingAssets/aa/*

# 🔹 추가: UI 및 리소스 관련 폴더 제외
Assets/UI/
Assets/Textures/
Assets/Fonts/
Assets/Animations/
Assets/Materials/
Assets/Audio/
Assets/Videos/
Assets/Prefabs/UI/
Assets/ThirdParty/

# 🔹 추가: 개인 및 보안 정보 제외
*.key
*.keystore
google-services.json
google-services.plist
Assets/Resources/secureData.json

# 🔹 유지할 파일 및 폴더 (포트폴리오 용도)
!Assets/Scripts/
!Assets/Blueprints/
!Assets/Data/
!README.md
